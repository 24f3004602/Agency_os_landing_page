# ─── App ───────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── SuperAdmin ────────────────────────────────────────────
SUPERADMIN_EMAIL=admin@agencyos.app
SUPERADMIN_PASSWORD=Admin@123

# ─── Database ──────────────────────────────────────────────
# Replace HOMELAB_IP with your homelab's IP
# If using Tailscale: use 100.x.x.x
# If on same WiFi: use 192.168.x.x
DATABASE_URL=postgresql+asyncpg://agencyos_user:agencyos_pass@HOMELAB_IP:5432/agencyos

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://HOMELAB_IP:6379/0

# ─── Qdrant ────────────────────────────────────────────────
QDRANT_HOST=HOMELAB_IP
QDRANT_PORT=6333

# ─── Embeddings (not needed until Module 3) ────────────────
EMBED_MODEL=tbd

# ─── Anthropic (not needed until Module 1 EOM agent) ───────
ANTHROPIC_API_KEY=

# ─── Gmail (not needed until Phase 4) ──────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/auth/gmail/callback

# ─── WATI (not needed until Phase 4) ───────────────────────
WATI_API_KEY=
WATI_BASE_URL=

# ─── HubSpot (not needed until M2) ─────────────────────────
HUBSPOT_ACCESS_TOKEN=

# ─── Slack (not needed until Phase 4) ──────────────────────
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=#agency-os-alerts

# ─── n8n ───────────────────────────────────────────────────
N8N_BASE_URL=http://HOMELAB_IP:5678
N8N_WEBHOOK_SECRET=

# ─── CORS ──────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ─── SerpAPI (M6) ──────────────────────────────────────────────────────────
SERPAPI_KEY=

# ─── Buffer (M5 — not needed until Phase 9) ────────────────────────────────
BUFFER_ACCESS_TOKEN=
BUFFER_DEFAULT_PROFILE_ID=